FROM node:20-alpine AS build

WORKDIR /app

COPY nutrivision-ui/package.json nutrivision-ui/package-lock.json* ./
RUN npm ci

COPY nutrivision-ui/ .
RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html

COPY nutrivision-ui/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
