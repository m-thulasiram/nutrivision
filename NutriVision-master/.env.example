# NutriVision Configuration
# Copy to .env and fill in values

# Application
NUTRIVISION_ENV=development

# Security (must be at least 32 characters)
NUTRIVISION_JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Database
# SQLite (default): relative or absolute path
# NUTRIVISION_DB_URL=./nutrivision.db
# PostgreSQL: connection string
# NUTRIVISION_DB_URL=postgresql://nutrivision:nutrivision@localhost:5432/nutrivision

# CORS (comma-separated origins)
NUTRIVISION_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT expiration (hours)
NUTRIVISION_JWT_EXPIRATION_HOURS=24

# YOLO model confidence threshold
NUTRIVISION_YOLO_CONFIDENCE=0.60

# Sentry DSN (optional)
# NUTRIVISION_SENTRY_DSN=
